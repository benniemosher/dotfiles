#!/bin/bash
# Install npm global packages
{{ range .packages.npm -}}
npm install -g {{ . | quote }}
{{ end }}
{{ if eq .chezmoi.os "darwin" -}}
brew bundle --file=/dev/stdin <<EOF
  {{ range .packages.darwin.taps.work -}}
  tap {{ . | quote }}
  {{ end -}}
  {{ if ne (env "WORK_PLATFORM") "1" -}}
  {{ range .packages.darwin.taps.personal -}}
  tap {{ . | quote }}
  {{ end -}}
  {{ end -}}

  {{ range .packages.darwin.brews.work -}}
  brew {{ . | quote }}
  {{ end -}}
  {{ if ne (env "WORK_PLATFORM") "1" -}}
  {{ range .packages.darwin.brews.personal -}}
  brew {{ . | quote }}
  {{ end -}}
  {{ end -}}

  {{ range .packages.darwin.casks.work -}}
  cask {{ . | quote }}
  {{ end -}}
  {{ if ne (env "WORK_PLATFORM") "1" -}}
  {{ range .packages.darwin.casks.personal -}}
  cask {{ . | quote }}
  {{ end -}}
  {{ end -}}
EOF
{{ else if eq .chezmoi.os "linux" -}}
sudo snap set system experimental.user-daemons=true
{{ range .packages.linux.apts -}}
sudo apt install {{ . | quote }}
{{ end }}
{{ range .packages.linux.snaps -}}
sudo snap install {{ . }}
{{ end }}
{{ end -}}
